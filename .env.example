# Langfuse (self-hosted)
YTFLOW_LANGFUSE_HOST=https://langfuse.your-host.com
YTFLOW_LANGFUSE_PUBLIC_KEY=pk-lf-...
YTFLOW_LANGFUSE_SECRET_KEY=sk-lf-...

# DeepSeek V4 (OpenAI-compatible)
YTFLOW_DEEPSEEK_API_KEY=<YOUR_DEEPSEEK_API_KEY>
YTFLOW_DEEPSEEK_BASE_URL=https://api.deepseek.com/
YTFLOW_DEEPSEEK_MODEL=deepseek-v4-flash

# Qwen TTS (DashScope international)
YTFLOW_QWEN_TTS_API_KEY=<YOUR_QWEN_TTS_API_KEY>
YTFLOW_QWEN_TTS_ENDPOINT=https://dashscope-intl.aliyuncs.com
YTFLOW_QWEN_TTS_MODEL=qwen3-tts-flash
YTFLOW_QWEN_TTS_VOICE=Cherry
YTFLOW_QWEN_TTS_CLONE_MODEL=qwen3-tts-vc-2026-01-22
YTFLOW_QWEN_TTS_CLONE_VOICE_PATH=data/voices/sutak.mp3
# Set true to write deterministic local silent WAVs instead of calling the cloud API.
YTFLOW_QWEN_TTS_MOCK=false

# Runtime artifact root (stage nodes write under {workspace}/{run_id}/).
YTFLOW_WORKSPACE_PATH=./workspace

# ComfyUI (local)
YTFLOW_COMFYUI_URL=http://localhost:8188
YTFLOW_COMFYUI_MOCK=false

# DB
YTFLOW_DB_PATH=yt_flow.db

# Subtitle alignment
YTFLOW_ALIGNER=whisperx
